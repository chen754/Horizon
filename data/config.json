{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-1.5-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": ["zh", "en"]
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 2,
      "min_score": 200
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      }
    ],
    "reddit": {
      "enabled": false
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 2
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 0.0,
    "time_window_hours": 24
  }
}
